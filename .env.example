# BookOne v2 — Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to git

# ============================================
# DATABASE
# ============================================
# PostgreSQL connection string
# Local: postgres://bookone:bookone@localhost:5432/bookone
# Docker: postgres://bookone:bookone@postgres:5432/bookone
DATABASE_URL=postgres://bookone:bookone@localhost:5432/bookone

# Individual DB connection params (used by prod compose for healthcheck)
DB_USER=bookone
DB_PASSWORD=bookone
DB_NAME=bookone
DB_HOST=localhost
DB_PORT=5432

# ============================================
# AUTHENTICATION (Better Auth)
# ============================================
# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=change-me-generate-with-openssl
BETTER_AUTH_URL=http://localhost:3000
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ============================================
# REDIS (Cache, Sessions, Job Queue)
# ============================================
# Local: redis://localhost:6379
# Docker: redis://redis:6379
REDIS_URL=redis://localhost:6379

# ============================================
# FILE STORAGE (MinIO / S3-compatible)
# ============================================
# For Cloudflare R2 in production, set:
#   S3_ENDPOINT=https://<ACCOUNT_ID>.r2.cloudflarestorage.com
#   S3_REGION=auto
#   S3_FORCE_PATH_STYLE=true
# See docs/CLOUDFLARE_R2_SETUP.md for bucket + token creation.
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=bookone
S3_REGION=us-east-1
S3_FORCE_PATH_STYLE=true
# Optional: public URL prefix for direct browser access (only if bucket is public)
S3_PUBLIC_URL=

# ============================================
# AI ASSISTANT (OpenAI)
# ============================================
OPENAI_API_KEY=sk-your-key-here
OPENAI_MODEL=gpt-4o-mini

# ============================================
# OBSERVABILITY
# ============================================
# Sentry DSN for error tracking
SENTRY_DSN=

# PostHog for product analytics (public key)
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# ============================================
# APPLICATION
# ============================================
NODE_ENV=development
APP_NAME=BookOne
APP_URL=http://localhost:3000

# ============================================
# MULTI-SERVICE HOSTS (Portainer / Traefik)
# See docs/PORTAINER_MULTI_SERVICE.md
# Staging under clossyan.com: use ONE-level subdomains only (Cloudflare free SSL).
#   GOOD: bookone.clossyan.com, bookone-docs.clossyan.com, bookone-e2e.clossyan.com
#   BAD:  docs.bookone.clossyan.com (nested → ERR_SSL_VERSION_OR_CIPHER_MISMATCH)
# Production on bookone.lk zone: docs.bookone.lk is OK (first-level under that zone).
# ============================================
WEB_HOST=bookone.clossyan.com
DOCS_HOST=bookone-docs.clossyan.com
E2E_HOST=bookone-e2e.clossyan.com
# Public HTTPS URL of ERP (auth + E2E default target + docs "Open app")
AUTH_URL=https://bookone.clossyan.com
BETTER_AUTH_URL=https://bookone.clossyan.com
DOCS_APP_URL=https://bookone.clossyan.com
E2E_BASE_URL=https://bookone.clossyan.com

# ============================================
# CRON / SCHEDULED JOBS
# ============================================
# Secret for securing cron job API endpoints
CRON_SECRET=change-me-generate-with-openssl

# ============================================
# PAYMENT (Future)
# ============================================
# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# PayHere (Sri Lanka)
PAYHERE_MERCHANT_ID=
PAYHERE_SECRET=

# ============================================
# EMAIL (Resend)
# ============================================
RESEND_API_KEY=
EMAIL_FROM=BookOne <noreply@bookone.clossyan.com>

# ============================================
# E2E (Playwright /apps/e2e-runner)
# ============================================
# CLI defaults. /e2e UI supplies target URL + credentials per run (no stack gates).
E2E_BASE_URL=http://localhost:3000
E2E_EMAIL=
E2E_PASSWORD=
# Optional: super-admin login for Control Room / health-check scenarios
E2E_ADMIN_EMAIL=
E2E_ADMIN_PASSWORD=
