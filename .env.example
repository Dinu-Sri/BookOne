# BookOne v2 — Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to git

# ============================================
# DATABASE
# ============================================
# PostgreSQL connection string
# Local: postgres://bookone:bookone@localhost:5432/bookone
# Docker: postgres://bookone:bookone@postgres:5432/bookone
DATABASE_URL=postgres://bookone:bookone@localhost:5432/bookone

# ============================================
# AUTHENTICATION (Auth.js v5)
# ============================================
# Generate with: openssl rand -base64 32
AUTH_SECRET=change-me-generate-with-openssl
AUTH_URL=http://localhost:3000

# ============================================
# REDIS (Cache, Sessions, Job Queue)
# ============================================
# Local: redis://localhost:6379
# Docker: redis://redis:6379
REDIS_URL=redis://localhost:6379

# ============================================
# FILE STORAGE (MinIO / S3-compatible)
# ============================================
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=bookone
S3_REGION=us-east-1

# ============================================
# AI ASSISTANT (OpenAI)
# ============================================
OPENAI_API_KEY=sk-your-key-here
OPENAI_MODEL=gpt-4o-mini

# ============================================
# OBSERVABILITY
# ============================================
# Sentry DSN for error tracking
SENTRY_DSN=

# PostHog for product analytics (public key)
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# ============================================
# APPLICATION
# ============================================
NODE_ENV=development
APP_NAME=BookOne
APP_URL=http://localhost:3000

# ============================================
# CRON / SCHEDULED JOBS
# ============================================
# Secret for securing cron job API endpoints
CRON_SECRET=change-me-generate-with-openssl

# ============================================
# PAYMENT (Future)
# ============================================
# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# PayHere (Sri Lanka)
PAYHERE_MERCHANT_ID=
PAYHERE_SECRET=

# ============================================
# EMAIL (Resend)
# ============================================
RESEND_API_KEY=
EMAIL_FROM=BookOne <noreply@bookone.clossyan.com>
