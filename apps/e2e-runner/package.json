{
  "name": "@bookone/e2e-runner",
  "version": "1.0.0",
  "private": true,
  "description": "Playwright E2E for BookOne — full UI automation + optional standalone console",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "start": "tsx src/server.ts",
    "test:e2e": "playwright test",
    "test:smoke": "playwright test tests/00-smoke.spec.ts",
    "test:full": "playwright test",
    "test:auth": "playwright test tests/01-auth.spec.ts",
    "test:shell": "playwright test tests/03-shell-routes.spec.ts",
    "test:masters": "playwright test tests/04-company-masters.spec.ts",
    "test:settings": "playwright test tests/12-settings-save.spec.ts",
    "test:sales": "playwright test tests/06-sales-journey.spec.ts",
    "test:purchase": "playwright test tests/07-purchase-inventory.spec.ts",
    "test:accounting": "playwright test tests/08-accounting.spec.ts",
    "test:pos": "playwright test tests/09-pos.spec.ts",
    "test:validation": "playwright test tests/13-validation-catalog.spec.ts",
    "test:day": "playwright test tests/15-business-day.spec.ts",
    "test:platform": "playwright test tests/17-platform.spec.ts",
    "test:routes": "playwright test tests/14-route-smoke-ids.spec.ts",
    "test:parties": "playwright test tests/16-parties-catalog.spec.ts",
    "test:matrices": "playwright test tests/20-qty-price-matrix.spec.ts tests/21-numeric-edges.spec.ts tests/22-reports-period-matrix.spec.ts tests/23-payment-status-matrix.spec.ts",
    "test:remainder": "playwright test tests/26-domain-remainder.spec.ts",
    "test:stress": "playwright test tests/25-stress.spec.ts",
    "coverage": "node scripts/generate-coverage.mjs",
    "postinstall": "playwright install chromium || true"
  },
  "dependencies": {
    "@playwright/test": "^1.51.0",
    "express": "^4.21.2",
    "tsx": "^4.19.0",
    "uuid": "^11.1.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.0.0",
    "typescript": "^5.5.0"
  }
}
