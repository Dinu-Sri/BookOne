# BookOne v2 — Production web (ERP only — no Chromium / E2E)
FROM node:22-alpine AS base
RUN apk add --no-cache libc6-compat
RUN npm install -g pnpm@9

FROM base AS builder
WORKDIR /app
ENV NEXT_TELEMETRY_DISABLED=1

COPY . .

RUN pnpm install --frozen-lockfile

ARG BUILD_DATE=0
RUN echo "Build: $BUILD_DATE" && rm -rf apps/web/.next apps/web/.turbo

# Build Next.js ERP app only
RUN pnpm --dir apps/web build

FROM base AS runner
WORKDIR /app

ENV NODE_ENV=production
ENV NEXT_TELEMETRY_DISABLED=1

RUN addgroup --system --gid 1001 nodejs \
 && adduser --system --uid 1001 nextjs

# Full monorepo build output (entrypoint runs migrations + next start)
COPY --from=builder --chown=nextjs:nodejs /app ./

RUN mkdir -p /app/.cache /app/.next /app/.pnpm-store \
 && chown -R nextjs:nodejs /app/.cache /app/.next /app/.pnpm-store

COPY docker/entrypoint.sh /entrypoint.sh
RUN chmod +x /entrypoint.sh

USER nextjs

EXPOSE 3100
ENV PORT=3100
ENV HOSTNAME="0.0.0.0"

ENTRYPOINT ["/entrypoint.sh"]
