# BookOne v2 — Production Dockerfile (Next.js standalone)
FROM node:20-alpine AS base
RUN apk add --no-cache libc6-compat
RUN npm install -g pnpm@9

FROM base AS builder
WORKDIR /app
ENV NEXT_TELEMETRY_DISABLED=1

COPY . .

RUN pnpm install --frozen-lockfile

ARG BUILD_DATE=0
RUN echo "Build: $BUILD_DATE" && rm -rf apps/web/.next apps/web/.turbo

# Build Next.js
RUN pnpm --dir apps/web build

FROM base AS runner
WORKDIR /app

ENV NODE_ENV=production
ENV NEXT_TELEMETRY_DISABLED=1

RUN addgroup --system --gid 1001 nodejs \
 && adduser --system --uid 1001 nextjs

# Copy built app and pre-installed deps
COPY --from=builder --chown=nextjs:nodejs /app ./

# Make a writable cache dir for the nextjs user (Next.js, pnpm store, etc.)
RUN mkdir -p /app/.cache /app/.next /app/.pnpm-store \
 && chown -R nextjs:nodejs /app/.cache /app/.next /app/.pnpm-store

# Copy and make entrypoint executable
COPY docker/entrypoint.sh /entrypoint.sh
RUN chmod +x /entrypoint.sh

USER nextjs

EXPOSE 3100
ENV PORT=3100
ENV HOSTNAME="0.0.0.0"

ENTRYPOINT ["/entrypoint.sh"]
