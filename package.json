{
  "name": "bookone",
  "version": "2.0.0",
  "private": true,
  "description": "BookOne v2 — Multi-tenant SaaS Accounting & ERP",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "test": "turbo test",
    "test:e2e": "playwright test",
    "db:migrate": "turbo db:migrate",
    "db:seed": "turbo db:seed",
    "db:seed-products": "tsx scripts/generate-demo-product-images.ts && tsx scripts/seed-demo-products.ts",
    "db:studio": "turbo db:studio",
    "db:init": "npx tsx scripts/init-db.ts",
    "clean": "turbo clean"
  },
  "devDependencies": {
    "turbo": "^2.9.0",
    "typescript": "^5.5.0"
  },
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.0.0",
  "dependencies": {
    "dotenv": "^16.4.0",
    "drizzle-orm": "^0.33.0",
    "postgres": "^3.4.0",
    "sharp": "^0.35.3",
    "tsx": "^4.19.0",
    "turbo": "^2.9.18"
  }
}
